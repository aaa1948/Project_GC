  m_TableData:
  - m_Id: 64544616472576
    m_Localized: "\uC5C5\uADF8\uB808\uC774"
    m_Metadata:
      m_Items: []
  - m_Id: 276406169031200768
    m_Localized: "\uB3C5\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276406260525748224
    m_Localized: "\uCE68\uC5D0 \uB3C5\uC744 \uBB3B\uD600 \uC801\uC911\uD55C \uC801\uC5D0\uAC8C
      \uC77C\uC815 \uC2DC\uAC04 \uC9C0\uC18D \uD53C\uD574\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276406403371159552
    m_Localized: "\uD3ED\uBC1C\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276406439320539136
    m_Localized: "\uCE68\uC774 \uC801\uC5D0\uAC8C \uC801\uC911\uD558\uBA74 \uD3ED\uBC1C\uC744
      \uC77C\uC73C\uCF1C \uC8FC\uBCC0 \uC801\uC5D0\uAC8C \uCD94\uAC00 \uD53C\uD574\uB97C
      \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276406486447738880
    m_Localized: "\uC720\uB3C4\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276406643037884416
    m_Localized: "\uCE68\uC774 \uC8FC\uBCC0\uC758 \uC801\uC744 \uCD94\uC801\uD558\uBA70
      \uD718\uC5B4\uC838 \uB0A0\uC544\uAC11\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276406846071558144
    m_Localized: "\uAD00\uD1B5\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276406902354923520
    m_Localized: "\uCE68\uC774 \uC801\uC744 \uAD00\uD1B5\uD558\uC5EC \uB4A4\uCABD\uC758
      \uC801\uAE4C\uC9C0 \uC5F0\uC18D\uC73C\uB85C \uACF5\uACA9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276406941647163392
    m_Localized: "\uAFC0\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276406983216910336
    m_Localized: "\uB048\uC801\uD55C \uCE68\uC73C\uB85C \uC801\uC911\uD55C \uC801\uC758
      \uC774\uB3D9 \uC18D\uB3C4\uB97C \uC77C\uC815 \uC2DC\uAC04 \uAC10\uC18C\uC2DC\uD0B5\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276407036195164160
    m_Localized: "\uBAA8\uAE30\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276407085163663360
    m_Localized: "\uCE68\uC774 \uC801\uC5D0\uAC8C \uC801\uC911\uD560 \uB54C\uB9C8\uB2E4
      \uCCB4\uB825\uC744 \uD68C\uBCF5\uD569\uB2C8\uB2E4. \uBCF4\uC2A4\uC5D0\uAC8C
      \uC801\uC911\uD558\uBA74 \uB354 \uB9CE\uC774 \uD68C\uBCF5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276407136451612672
    m_Localized: "\uCE68\uADC0\uD658"
    m_Metadata:
      m_Items: []
  - m_Id: 276407167992778752
    m_Localized: "\uCE68\uC774 \uC801\uC911\uD55C \uB4A4 \uD50C\uB808\uC774\uC5B4\uC5D0\uAC8C
      \uB418\uB3CC\uC544\uC624\uBA70, \uADC0\uD658 \uACBD\uB85C\uC758 \uC801\uC5D0\uAC8C
      \uD53C\uD574\uB97C \uC90D\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276407202587398144
    m_Localized: "\uCE68\uC220\uC9C4"
    m_Metadata:
      m_Items: []
  - m_Id: 276407238444503040
    m_Localized: "\uB300\uC26C \uD69F\uC218\uAC00 1 \uC99D\uAC00\uD569\uB2C8\uB2E4.
      \uB300\uC26C\uD560 \uB54C \uC2DC\uC791 \uC704\uCE58\uC5D0 \uBD84\uC2E0\uC744
      \uB0A8\uACA8 \uC0AC\uBC29\uC73C\uB85C \uCE68\uC744 \uBC1C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276407276457480192
    m_Localized: "\uC0DD\uBA85\uC5F0\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 276408032623382528
    m_Localized: "\uCD5C\uB300 \uCCB4\uB825\uC774 1\uC774 \uB418\uACE0 \uD68C\uBCF5\uD560
      \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uB300\uC2E0 \uCE68\uC758 \uD53C\uD574\uB7C9,
      \uBC1C\uC0AC \uC218, \uC0AC\uAC70\uB9AC\uAC00 \uD06C\uAC8C \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276408321405407232
    m_Localized: "\uBD84\uC2E0\uBC30\uC591"
    m_Metadata:
      m_Items: []
  - m_Id: 276408385523732480
    m_Localized: "\uD50C\uB808\uC774\uC5B4\uB97C \uB530\uB77C\uB2E4\uB2C8\uB294 \uBD84\uC2E0\uC744
      \uC0DD\uC131\uD569\uB2C8\uB2E4. \uBD84\uC2E0\uC740 \uD604\uC7AC \uCE68 \uB2A5\uB825\uC744
      \uAE30\uBC18\uC73C\uB85C \uD568\uAED8 \uACF5\uACA9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276408415978573824
    m_Localized: "\uACE0\uC2B4\uB3C4\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276408451193950208
    m_Localized: "\uD50C\uB808\uC774\uC5B4 \uC8FC\uBCC0\uC744 \uD68C\uC804\uD558\uB294
      \uCE68 \uACB0\uACC4\uB97C \uC0DD\uC131\uD569\uB2C8\uB2E4. \uC801\uC774 \uACB0\uACC4\uC5D0
      \uB2FF\uC73C\uBA74 \uBC18\uACA9 \uCE68\uC744 \uBC1C\uC0AC\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276408486942003200
    m_Localized: "\uB300\uBB3C\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276408529585491968
    m_Localized: "\uC774\uAE30\uC5B4\uCE68"
    m_Metadata:
      m_Items: []
  - m_Id: 276408564805062656
    m_Localized: "\uAE30\uBCF8 \uC790\uB3D9 \uACF5\uACA9\uC744 \uC911\uC9C0\uD558\uACE0,
      \uB9C8\uC6B0\uC2A4 \uC704\uCE58\uB97C \uB530\uB77C \uC6C0\uC9C1\uC774\uB294
      \uC870\uC885 \uCE68\uC744 \uC0DD\uC131\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 276410096367751168
    m_Localized: "\uACF5\uACA9 \uBC84\uD2BC\uC744 \uAE38\uAC8C \uB20C\uB7EC \uAC15\uB825\uD55C
      \uCC28\uC9C0 \uCE68\uC744 \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uCDA9\uC804\uD560\uC218\uB85D
      \uD53C\uD574\uB7C9, \uD06C\uAE30, \uC18D\uB3C4, \uAD00\uD1B5\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
