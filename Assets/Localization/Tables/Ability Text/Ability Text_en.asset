  m_TableData:
  - m_Id: 276406169031200768
    m_Localized: "Poison Needle\t"
    m_Metadata:
      m_Items: []
  - m_Id: 276406260525748224
    m_Localized: Coats needles with poison, dealing damage over time to enemies hit.
    m_Metadata:
      m_Items: []
  - m_Id: 276406403371159552
    m_Localized: Explosive Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276406439320539136
    m_Localized: Needles explode on hit, dealing additional damage to nearby enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 276406486447738880
    m_Localized: Homing Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276406643037884416
    m_Localized: Needles curve toward nearby enemies while flying.
    m_Metadata:
      m_Items: []
  - m_Id: 276406846071558144
    m_Localized: Piercing Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276406902354923520
    m_Localized: Needles pierce through enemies and continue hitting targets behind
      them.
    m_Metadata:
      m_Items: []
  - m_Id: 276406983216910336
    m_Localized: Sticky needles slow enemies for a short time on hit.
    m_Metadata:
      m_Items: []
  - m_Id: 276406941647163392
    m_Localized: Honey Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276407036195164160
    m_Localized: Mosquito Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276407085163663360
    m_Localized: Restores health whenever a needle hits an enemy. Hitting a boss
      restores more health.
    m_Metadata:
      m_Items: []
  - m_Id: 276407136451612672
    m_Localized: Returning Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276407167992778752
    m_Localized: Needles return to the player after hitting an enemy, damaging enemies
      along the return path.
    m_Metadata:
      m_Items: []
  - m_Id: 276407202587398144
    m_Localized: Acupuncture Formation
    m_Metadata:
      m_Items: []
  - m_Id: 276407238444503040
    m_Localized: Gain 1 additional dash charge. Dashing leaves a clone at the starting
      point that fires needles in all directions.
    m_Metadata:
      m_Items: []
  - m_Id: 276407276457480192
    m_Localized: Life Burn
    m_Metadata:
      m_Items: []
  - m_Id: 276408032623382528
    m_Localized: Set maximum health to 1 and prevent healing. In exchange, greatly
      increases needle damage, projectile count, and range.
    m_Metadata:
      m_Items: []
  - m_Id: 276408321405407232
    m_Localized: Clone Culture
    m_Metadata:
      m_Items: []
  - m_Id: 276408385523732480
    m_Localized: Creates a clone that follows the player and attacks using the current
      needle ability.
    m_Metadata:
      m_Items: []
  - m_Id: 276408451193950208
    m_Localized: Creates a rotating needle barrier around the player. Enemies that
      touch it trigger counter needles.
    m_Metadata:
      m_Items: []
  - m_Id: 276408415978573824
    m_Localized: Hedgehog Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276408486942003200
    m_Localized: Heavy Snipe
    m_Metadata:
      m_Items: []
  - m_Id: 276408529585491968
    m_Localized: Sword-Control Needle
    m_Metadata:
      m_Items: []
  - m_Id: 276408564805062656
    m_Localized: Stops the basic automatic attack and creates a controllable needle
      that follows the mouse position.
    m_Metadata:
      m_Items: []
  - m_Id: 276410096367751168
    m_Localized: Hold the attack button to fire a powerful charged needle. The longer
      it charges, the more damage, size, speed, and piercing power it gains.
    m_Metadata:
      m_Items: []
  - m_Id: 64544616472576
    m_Localized: Upgrade
    m_Metadata:
      m_Items: []
  - m_Id: 276416827978207232
    m_Localized: Genaral Ability
    m_Metadata:
      m_Items: []
  - m_Id: 276416830738059264
    m_Localized: Genaral reason Ability
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
